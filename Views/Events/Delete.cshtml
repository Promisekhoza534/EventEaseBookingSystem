@model EventEase.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="card card-custom p-4">
    <h2 class="page-title text-danger">Delete Event</h2>
    <p>Are you sure you want to delete this event?</p>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Event Name</dt>
        <dd class="col-sm-9">@Model.EventName</dd>

        <dt class="col-sm-3">Event Date</dt>
        <dd class="col-sm-9">@Model.EventDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Venue</dt>
        <dd class="col-sm-9">@Model.Venue?.VenueName</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="EventId" />
        <button type="submit" class="btn btn-danger btn-custom">Delete</button>
        <a asp-action="Index" class="btn btn-secondary btn-custom">Cancel</a>
    </form>
</div>