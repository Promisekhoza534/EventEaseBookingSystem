@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="events-page-header">
    <h1 class="events-page-title">All Events</h1>
    <a asp-action="Create" class="btn create-event-btn">+ Create Event</a>
</div>

<div class="events-grid">
    @foreach (var item in Model)
    {
        <div class="event-card-box">
            <div class="event-image-wrap">
                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=1200&q=80" : item.ImageUrl)"
                     alt="@item.EventName" class="event-image" />
            </div>

            <div class="event-card-content">
                <h3 class="event-title">@item.EventName</h3>

                <p class="event-meta">
                    <i class="bi bi-calendar-event"></i>
                    @item.EventDate.ToString("dddd, MMM dd yyyy • hh:mm tt")
                </p>

                <p class="event-meta">
                    <i class="bi bi-geo-alt-fill"></i>
                    @item.Venue?.VenueName
                </p>

                <p class="event-meta">
                    <i class="bi bi-people-fill"></i>
                    Capacity: @(item.Venue != null ? item.Venue.Capacity : 0)
                </p>

                <p class="event-meta">
                    <i class="bi bi-check-circle-fill"></i>
                    @if (item.Venue != null && item.Venue.Availability)
                    {
                        <span class="availability-yes">Available</span>
                    }
                    else
                    {
                        <span class="availability-no">Unavailable</span>
                    }
                </p>

                <p class="event-description">
                    @item.Description
                </p>
            </div>

            <div class="event-card-actions">
                <a asp-action="Details" asp-route-id="@item.EventId" class="btn action-btn action-details">Details</a>
                <a asp-action="Edit" asp-route-id="@item.EventId" class="btn action-btn action-edit">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.EventId" class="btn action-btn action-delete">Delete</a>
            </div>
        </div>
    }
</div>