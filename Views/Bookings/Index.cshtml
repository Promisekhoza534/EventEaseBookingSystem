@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="events-page-header">
    <h1 class="events-page-title">All Bookings</h1>
    <a asp-action="Create" class="btn create-event-btn">+ Create Booking</a>
</div>

<div class="card card-custom p-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar"></i> Date</th>
                    <th><i class="bi bi-person-fill"></i> Customer</th>
                    <th><i class="bi bi-envelope-fill"></i> Email</th>
                    <th><i class="bi bi-calendar-event-fill"></i> Event</th>
                    <th><i class="bi bi-geo-alt-fill"></i> Venue</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerContact</td>
                        <td>@item.Event?.EventName</td>
                        <td>@item.Venue?.VenueName</td>
                        <td class="text-center action-buttons">
                            <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-edit">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-details">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>