@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="card card-custom p-4">
    <h2 class="page-title text-danger">Delete Venue</h2>
    <p>Are you sure you want to delete this venue?</p>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Venue Name</dt>
        <dd class="col-sm-9">@Model.VenueName</dd>

        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Location</dd>

        <dt class="col-sm-3">Capacity</dt>
        <dd class="col-sm-9">@Model.Capacity</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="VenueId" />
        <button type="submit" class="btn btn-danger btn-custom">Delete</button>
        <a asp-action="Index" class="btn btn-secondary btn-custom">Cancel</a>
    </form>
</div>