@{
    ViewData["Title"] = "Privacy";
}

<div class="privacy-page">
    <div class="privacy-hero">
        <h1 class="privacy-title">
            <i class="bi bi-shield-lock-fill me-2"></i>Privacy Policy
        </h1>
        <p class="privacy-subtitle">
            Your information matters to us. EventEase is committed to protecting user data and ensuring privacy when managing events, venues, and bookings.
        </p>
    </div>

    <div class="privacy-card">
        <h3><i class="bi bi-database-lock me-2"></i>Information We Collect</h3>
        <p>
            EventEase stores booking, event, and venue details entered by users in order to manage the application effectively.
            This may include names, booking dates, customer contact details, venue details, and event information.
        </p>
    </div>

    <div class="privacy-card">
        <h3><i class="bi bi-person-check-fill me-2"></i>How We Use Your Information</h3>
        <p>
            The information collected is used only for managing venues, events, and bookings within the EventEase system.
            It helps staff organize event schedules, track reservations, and maintain accurate booking records.
        </p>
    </div>

    <div class="privacy-card">
        <h3><i class="bi bi-shield-check me-2"></i>Data Protection</h3>
        <p>
            EventEase uses secure cloud services such as Microsoft Azure and Azure SQL Database to protect stored data.
            Access to information is restricted to authorized users, and the system is designed to reduce data loss,
            unauthorized access, and duplication.
        </p>
    </div>

    <div class="privacy-card">
        <h3><i class="bi bi-arrow-repeat me-2"></i>Policy Updates</h3>
        <p>
            This privacy policy may be updated from time to time to reflect improvements in the EventEase application,
            security practices, or system requirements.
        </p>
    </div>
</div>
